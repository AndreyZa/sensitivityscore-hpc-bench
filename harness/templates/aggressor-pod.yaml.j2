{# aggressor-pod.yaml.j2 — фоновый LLC/membw-агрессор pressure-сценария,
   рендерится harness/submit/aggressors.py по одному поду на (нода, слот).

   nodeName — ПРЯМАЯ привязка к ноде, мимо любого планировщика: ландшафт
   давления должен быть идентичным для обоих плеч сравнения (A-default и
   A-sensitivityscore), иначе сравнение плеч нечестное.

   cpu request НАМЕРЕННО маленький при заметно большем limit: ресурсная
   модель default-планировщика видит почти свободную ноду, а реальное
   давление на LLC/полосу памяти при этом большое — ровно тот случай, где
   requests недопредставляют контенцию по разделяемым ресурсам (научный
   тезис pressure-эксперимента). #}
apiVersion: v1
kind: Pod
metadata:
  name: {{ name }}
  namespace: {{ namespace }}
  labels:
    app: ss-aggressor
    sensitivityscore.phd/scenario: "{{ scenario }}"
  annotations:
    scheduling.phd/sensitivity-llc: "low"
    scheduling.phd/sensitivity-numa: "low"
    scheduling.phd/sensitivity-net: "low"
    scheduling.phd/sensitivity-io: "low"
spec:
  nodeName: {{ node_name }}
  restartPolicy: Never
  containers:
    - name: stress
      image: {{ image }}
      imagePullPolicy: Always # конвенция репо: dev-теги мутабельны, нода не должна жить с закэшированным старым образом
      {# По умолчанию ENTRYPOINT образа — stress-ng, args приходят из сценария
         (aggressor_args: --stream для LLC/membw, --hdd для диска) поверх
         фиксированного --temp-path: временные файлы IO-стрессоров пишутся в
         /scratch (emptyDir -> реальный диск ноды). Без --timeout: "--timeout
         0" у stress-ng = "0 секунд" (мгновенный выход), бесконечный прогон —
         дефолт без флага. Net-шторм (aggressors.py) переопределяет command
         целиком (iperf3 сервер/клиент). #}
      {% if command_json %}
      command: {{ command_json }}
      {% endif %}
      {% if args_json %}
      args: {{ args_json }}
      {% endif %}
      volumeMounts:
        - name: scratch
          mountPath: /scratch
      {# И cpu, И memory request маленькие — иначе агрессор виден ресурсной
         модели default по ЛЮБОЙ из осей и та уводит от него поды не из-за
         интерференции (на STAGE 512Mi-request агрессора не давал жертве 1Gi
         влезть на 1.9Gi-ноду — оба планировщика избегали её по памяти). #}
      resources:
        requests:
          cpu: "{{ cpu_request }}"
          memory: "{{ mem_request | default('512Mi') }}"
        limits:
          cpu: "{{ cpu_limit }}"
          memory: "{{ mem_limit | default('2Gi') }}"
  volumes:
    - name: scratch
      emptyDir:
        sizeLimit: 8Gi # --hdd пишет реальные файлы; ограничить, чтобы не довести ноду до eviction
