#!/usr/bin/env bash
#SBATCH --job-name={{ job_id }}
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task={{ env.G4_THREADS }}
#SBATCH --mem={{ resources.memory_request }}
#SBATCH --time=00:30:00
#SBATCH --output=results/{{ job_id }}-%j.out
{% if overcommit > 1.0 -%}
#SBATCH --oversubscribe
{% endif -%}
#
# Rendered by harness/submit/slurm_submit.py for job_id={{ job_id }}
# (config=C profile={{ profile }} overcommit={{ overcommit }}).
set -euo pipefail

{# Весь env профиля (profiles.py) как есть — профили различаются набором
   переменных (например, IO_BURST_MB только у high-s-io). #}
{% for key, value in env.items() -%}
export {{ key }}="{{ value }}"
{% endfor %}
echo "[sbatch] job_id={{ job_id }} threads=${G4_THREADS} physics_list=${PHYSICS_LIST} \
n_primaries=${N_PRIMARIES} output_mode=${OUTPUT_MODE} seed=${RNG_SEED} slurm_job_id=${SLURM_JOB_ID}"

srun --container-image={{ image | default("sensitivityscore-bench/geant4:11.2") }} \
  --container-env={{ env.keys() | join(",") }} \
  /entrypoint.sh
