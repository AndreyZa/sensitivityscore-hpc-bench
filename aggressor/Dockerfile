# aggressor/ — синтетический «агрессор» для pressure-сценариев харнесса
# (см. harness/README.md, «Pressure-сценарий»). Один образ на два вида шторма:
#
# 1) stress-ng (ENTRYPOINT по умолчанию):
#    --stream — STREAM-подобный полутёр памяти: непрерывные потоковые
#    чтения/записи вытесняют чужие данные из LLC и забивают полосу памяти;
#    --hdd — дисковый шторм (IO-давление видно в PSI io.pressure).
# 2) iperf3 (Net-шторм, харнесс переопределяет command в манифесте):
#    пара сервер+клиент НА ОДНОЙ штормимой ноде, UDP с фиксированным -b —
#    трафик идёт pod-to-pod через veth, засвечивая net_bw/net_pressure только
#    штормимой ноды (cross-node пара засветила бы и принимающую ноду).
#
# Ключевое свойство для эксперимента: под с МАЛЕНЬКИМ cpu/mem-request
# (см. harness/templates/aggressor-pod.yaml.j2) невидим для ресурсной модели
# default-планировщика — нода выглядит свободной, — но создаёт давление,
# которое видит metrics-agent и учитывает SensitivityScore.
FROM alpine:3.20
RUN apk add --no-cache stress-ng iperf3
ENTRYPOINT ["stress-ng"]
# Дефолт для ручного запуска; харнесс передаёт свои args (--stream N).
# ВАЖНО: без --timeout — у stress-ng "--timeout 0" означает "0 секунд на
# стрессор" (мгновенный выход), а НЕ "бесконечно"; бесконечный прогон — это
# дефолт при отсутствии флага (под живёт, пока харнесс его не удалит).
CMD ["--stream", "2"]
