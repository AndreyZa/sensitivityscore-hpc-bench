# aggressor/ — синтетический LLC/memory-bandwidth «агрессор» для pressure-
# сценариев харнесса (см. harness/README.md, «Pressure-сценарий»).
#
# stress-ng --stream — STREAM-подобный полутёр памяти: непрерывные потоковые
# чтения/записи вытесняют чужие данные из LLC и забивают полосу памяти, при
# этом сам стрессор к интерференции нечувствителен (нет переиспользования
# данных). Ключевое свойство для эксперимента: под с МАЛЕНЬКИМ cpu-request
# (см. harness/templates/aggressor-pod.yaml.j2) невидим для ресурсной модели
# default-планировщика — нода выглядит свободной, — но создаёт давление,
# которое видит metrics-agent и учитывает SensitivityScore.
FROM alpine:3.20
RUN apk add --no-cache stress-ng
ENTRYPOINT ["stress-ng"]
# Дефолт для ручного запуска; харнесс передаёт свои args (--stream N).
# ВАЖНО: без --timeout — у stress-ng "--timeout 0" означает "0 секунд на
# стрессор" (мгновенный выход), а НЕ "бесконечно"; бесконечный прогон — это
# дефолт при отсутствии флага (под живёт, пока харнесс его не удалит).
CMD ["--stream", "2"]
