# --- Go ---
scheduler-plugin/*.exe
metrics-agent/*.exe
**/bin/
go.work
go.work.sum

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/

# --- Experiment outputs (results are data, not code — keep the repo light) ---
harness/results/*.parquet
harness/results/*.out
harness/*.log
harness/*.out
statusserver/*.out
# Отчёты анализа — производные от parquet/ClickHouse, пересобираются одной
# командой. Маска общая (report*), а не перечисление: прежняя report-stage*
# не покрыла report-ablation, и каталог светился в статусе как неотслеживаемый.
analysis/report*/

# --- OS / editor ---
.DS_Store
*.swp
.idea/
.vscode/

# --- Terraform/kube local state, if ever added ---
*.tfstate
*.tfstate.*
kubeconfig*

# служебные файлы кнопки make series
harness/.series-*
harness/.redis-pf.*
# параметры последней поднятой страницы — состояние конкретного хоста
harness/.status-page.env

# генерируется make series PILOT=1
harness/.pilot-*.sh
