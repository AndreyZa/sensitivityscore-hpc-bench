# Контекст сборки для образа статус-страницы — корень репозитория
# (statusserver/Dockerfile). Остальные образы собираются из своих подкаталогов,
# на них этот файл не влияет.
#
# Главное здесь — __pycache__: хостовые .pyc собраны питоном 3.14, а в образе
# 3.12, толку от них ноль, а в слой они попадают и путают при разборе «что
# внутри образа».
__pycache__/
*.pyc
*.pyo

# Виртуальные окружения и данные прогонов — сотни мегабайт, странице не нужны
# (в контейнере она читает смонтированные пути).
.venv/
*/.venv/
harness/results/
analysis/report*/
*.parquet
*.log

.git/
.github/
*.md
